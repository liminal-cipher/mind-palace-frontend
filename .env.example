# Mind Palace 백엔드 환경변수 예시(.env). 실제 값은 .env 또는 Azure App Service 앱 설정에 둔다.
# 로컬은 backend/app/main.py 가 프로젝트 루트의 .env 를 자동 로드한다.

# ── 지도(vworld) ─────────────────────────────────────────────────────────────
VWORLD_API_KEY=

# ── Azure Blob Storage ───────────────────────────────────────────────────────
# 두 컨테이너로 분리해 쓴다(같은 스토리지 계정):
#   models  : 3D GLB 모델 (sketchfab.py) — 이미 존재
#   library : 서재 payload(palace/designs JSON) — 첫 사용 시 자동 생성
# 미설정이면 서재 payload 는 Cosmos 문서에 인라인 저장(작은 궁전만, 2MB 미만).
AZURE_STORAGE_CONNECTION_STRING=
LIBRARY_BLOB_CONTAINER=library   # 기본 library

# ── Azure Cosmos DB (사용자 프로필 + 서재 메타데이터) ───────────────────────
# 엔드포인트 + 키로 인증 (또는 AZURE_COSMOS_CONNECTION_STRING 하나로도 가능)
AZURE_COSMOS_ENDPOINT=
AZURE_COSMOS_KEY=
# 선택값
AZURE_COSMOS_DB_NAME=mindpalace
AZURE_COSMOS_MAX_RU=1000               # 프로비저닝 오토스케일 상한 RU/s (DB 레벨 공유)
# AZURE_COSMOS_SERVERLESS=true         # 서버리스 계정일 때만

# ── Azure AI Vision (객체/캡션 인식) ─────────────────────────────────────────
AZURE_VISION_ENDPOINT=
AZURE_VISION_KEY=

# ── Sketchfab 가져오기 ───────────────────────────────────────────────────────
SKETCHFAB_API_TOKEN=

# ── LLM 챗(도시 추천 등) — Azure OpenAI 우선, 없으면 OpenAI ──────────────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2025-01-01-preview
# 또는
OPENAI_API_KEY=
OPENAI_MODEL=
